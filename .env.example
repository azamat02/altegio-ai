NODE_ENV=development
PORT=3000

# Dev uses localhost (docker-compose.yml exposes ports).
# On VPS with docker-compose.prod.yml, replace host with service names: postgres:5432 / redis:6379
DATABASE_URL=postgresql://altegio:altegio_dev@localhost:5432/altegio_ai
REDIS_URL=redis://localhost:6379

ALTEGIO_BASE_URL=https://api.alteg.io/api/v1
ALTEGIO_PARTNER_TOKEN=replace_me
ALTEGIO_USER_TOKEN=replace_me

ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_OWNER_CHAT_ID=replace_me

APP_ENCRYPTION_KEY=replace_with_32_byte_hex

SENTRY_DSN=
LOG_LEVEL=info

# Set to true only in the API server process; keep false for CLI and tests
SCHEDULER_ENABLED=false

# Prod compose: ghcr.io/<owner>/altegio-ai-api:latest is pulled on VPS
GHCR_OWNER=azamat02
POSTGRES_USER=altegio
POSTGRES_PASSWORD=replace_me
